# ========== 应用（生产环境模板，复制为 .env 后修改）==========
APP_NAME=嘉岭佰
ENV=production
# 生成方式: openssl rand -hex 32
SECRET_KEY=请替换为至少32位随机字符串
JWT_EXPIRE_HOURS=168
CORS_ORIGINS=https://carlingbuy.com,https://www.carlingbuy.com

# ========== 数据库 ==========
POSTGRES_USER=jianji
POSTGRES_PASSWORD=请替换为强密码
POSTGRES_DB=jianji
DATABASE_URL=postgresql+psycopg2://jianji:请替换为强密码@db:5432/jianji

# ========== Redis ==========
REDIS_URL=redis://redis:6379/0

# ========== 短信 ==========
# 上线默认关闭；接入阿里云后设 SMS_ENABLED=true
SMS_ENABLED=false
SMS_MOCK_CODE=123456
SMS_CODE_EXPIRE_MINUTES=10
SMS_SEND_INTERVAL_SECONDS=60
SMS_PROVIDER=mock
ALIYUN_ACCESS_KEY_ID=
ALIYUN_ACCESS_SECRET=
ALIYUN_SMS_SIGN_NAME=
ALIYUN_SMS_TEMPLATE_REGISTER=
ALIYUN_SMS_TEMPLATE_RESET_PASSWORD=

# ========== 行情 Worker ==========
MARKET_DATA_PROVIDER=akshare
WORKER_ENABLED=true
TRACKING_CRON_HOUR=16
TRACKING_CRON_MINUTE=00

# ========== 管理员（首次启动自动创建）==========
ADMIN_PHONE=请替换为管理员手机号
ADMIN_PASSWORD=请替换为强密码
ADMIN_NICKNAME=系统管理员

# ========== 演示账号 ==========
SEED_DEMO_USER=false

# ========== 前端构建 ==========
VITE_API_BASE_URL=/api
