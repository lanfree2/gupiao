# ========== 应用 ==========
APP_NAME=荐迹
ENV=production
SECRET_KEY=change-this-to-a-long-random-string-in-production
JWT_EXPIRE_HOURS=168
CORS_ORIGINS=http://localhost,http://localhost:5173,http://127.0.0.1

# ========== 数据库 ==========
POSTGRES_USER=jianji
POSTGRES_PASSWORD=jianji_secret_change_me
POSTGRES_DB=jianji
DATABASE_URL=postgresql+psycopg2://jianji:jianji_secret_change_me@db:5432/jianji

# ========== Redis ==========
REDIS_URL=redis://redis:6379/0

# ========== 短信（开关） ==========
# false = 演示模式：验证码固定为 SMS_MOCK_CODE，接口仍可用
SMS_ENABLED=false
SMS_MOCK_CODE=123456
SMS_CODE_EXPIRE_MINUTES=10
SMS_SEND_INTERVAL_SECONDS=60

# 接入阿里云短信后设 SMS_ENABLED=true 并填写：
SMS_PROVIDER=mock
ALIYUN_ACCESS_KEY_ID=
ALIYUN_ACCESS_SECRET=
ALIYUN_SMS_SIGN_NAME=
ALIYUN_SMS_TEMPLATE_REGISTER=
ALIYUN_SMS_TEMPLATE_RESET_PASSWORD=

# ========== 行情 Worker ==========
MARKET_DATA_PROVIDER=akshare
WORKER_ENABLED=true
# 工作日 16:30 跑节点抓取（容器内 cron 或手动触发）
TRACKING_CRON_HOUR=16
TRACKING_CRON_MINUTE=30

# ========== 管理员（首次 seed） ==========
ADMIN_PHONE=13800000000
ADMIN_PASSWORD=admin123_change_me
ADMIN_NICKNAME=系统管理员

# ========== 演示账号 seed ==========
# Docker 首次启动时创建 13888888888 / demo123456
SEED_DEMO_USER=true

# ========== 前端构建 ==========
VITE_API_BASE_URL=/api
